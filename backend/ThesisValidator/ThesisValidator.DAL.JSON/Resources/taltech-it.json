      "ruleName": "appendix_title_format",
      "type": "regex",
      "enabled": true,
      "target": "paragraph",
      "property": "text",
      "pattern": "^Lisa \\d+ \u2013 .+",
      "afterSectionTitle": "Kasutatud kirjandus",
      "severity": "error",
      "description": "Lisade pealkirjad on formaadis 'Lisa 1 – Pealkiri'",
      "message": "Lisa pealkiri peab algama kujul 'Lisa 1 – Pealkiri'"
