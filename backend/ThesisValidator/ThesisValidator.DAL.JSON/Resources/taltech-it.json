      "ruleId": "C-003",
      "ruleName": "main_content_page_count_master",
      "type": "count",
      "enabled": true,
      "target": "document",
      "property": "pageCount",
      "startSectionTitle": "Sissejuhatus",
      "endSectionTitle": "Kokkuvõte",
