{
  "templateId": "taltech-it",
  "name": "TalTech IT-teaduskonna lõputöö vormistusjuhend",
  "version": "2025",
  "rules": [
    {
      "ruleId": "page_margin_top",
      "type": "numeric",
      "enabled": true,
      "target": "page",
      "property": "marginTop",
      "expectedValue": 2.5,
      "unit": "cm",
      "tolerance": 0.05,
      "severity": "error",
      "description": "Ülemine veeris",
      "message": "Ülemine veeris peab olema 2,5 cm"
    },
    {
      "ruleId": "page_margin_bottom",
      "type": "numeric",
      "enabled": true,
      "target": "page",
      "property": "marginBottom",
      "expectedValue": 2.5,
      "unit": "cm",
      "tolerance": 0.05,
      "severity": "error",
      "description": "Alumine veeris",
      "message": "Alumine veeris peab olema 2,5 cm"
    },
    {
      "ruleId": "page_margin_left",
      "type": "numeric",
      "enabled": true,
      "target": "page",
      "property": "marginLeft",
      "expectedValue": 3.0,
      "unit": "cm",
      "tolerance": 0.05,
      "severity": "error",
      "description": "Vasak veeris",
      "message": "Vasak veeris peab olema 3,0 cm"
    },
    {
      "ruleId": "page_margin_right",
      "type": "numeric",
      "enabled": true,
      "target": "page",
      "property": "marginRight",
      "expectedValue": 3.0,
      "unit": "cm",
      "tolerance": 0.05,
      "severity": "error",
      "description": "Parem veeris",
      "message": "Parem veeris peab olema 3,0 cm"
    },
    {
      "ruleId": "page_margin_footer",
      "type": "numeric",
      "enabled": true,
      "target": "page",
      "property": "marginFooter",
      "expectedValue": 1.5,
      "unit": "cm",
      "tolerance": 0.05,
      "severity": "error",
      "description": "Leheküljenumbri kaugus servast",
      "message": "Leheküljenumber peab asuma 1,5 cm kaugusel alumisest servast"
    },
    {
      "ruleId": "font_size_body",
      "type": "numeric",
      "enabled": true,
      "target": "paragraph",
      "property": "fontSize",
      "expectedValue": 12.0,
      "unit": "pt",
      "tolerance": 0.5,
      "severity": "error",
      "description": "Põhiteksti fondi suurus",
      "message": "Põhiteksti fondi suurus peab olema 12 pt",
      "styleFilters": [
        "Normal"
      ]
    },
    {
      "ruleId": "font_size_heading1",
      "type": "numeric",
      "enabled": true,
      "target": "paragraph",
      "property": "fontSize",
      "expectedValue": 16.0,
      "unit": "pt",
      "tolerance": 0.5,
      "severity": "error",
      "description": "I taseme peakirja fondi suurus",
      "message": "I taseme peakirja fondi suurus peab olema 16 pt",
      "styleFilters": [
        "Heading1",
        "Heading",
        "Heading_unnumber",
        "TOC1"
      ]
    },
    {
      "ruleId": "font_size_heading2",
      "type": "numeric",
      "enabled": true,
      "target": "paragraph",
      "property": "fontSize",
      "expectedValue": 14.0,
      "unit": "pt",
      "tolerance": 0.5,
      "severity": "error",
      "description": "II taseme peakirja fondi suurus",
      "message": "II taseme peakirja fondi suurus peab olema 14 pt",
      "styleFilters": [
        "Heading2"
      ]
    },
    {
      "ruleId": "font_size_heading3",
      "type": "numeric",
      "enabled": true,
      "target": "paragraph",
      "property": "fontSize",
      "expectedValue": 12.0,
      "unit": "pt",
      "tolerance": 0.5,
      "severity": "error",
      "description": "III taseme peakirja fondi suurus",
      "message": "III taseme peakirja fondi suurus peab olema 12 pt",
      "styleFilters": [
        "Heading3"
      ]
    },
    {
      "ruleId": "font_size_toc",
      "type": "numeric",
      "enabled": true,
      "target": "paragraph",
      "property": "fontSize",
      "expectedValue": 12.0,
      "unit": "pt",
      "tolerance": 0.5,
      "severity": "error",
      "description": "Sisukorra teksti fondi suurus",
      "message": "Sisukorra teksti fondi suurus peab olema 12 pt",
      "styleFilters": [
        "TOC2",
        "TOC3"
      ]
    },
    {
      "ruleId": "font_size_caption",
      "type": "numeric",
      "enabled": true,
      "target": "paragraph",
      "property": "fontSize",
      "expectedValue": 10.0,
      "unit": "pt",
      "tolerance": 0.5,
      "severity": "error",
      "description": "Tabeli või joonise pealkirja fondi suurus",
      "message": "Tabeli või joonise pealkirja fondi suurus peab olema 10 pt",
      "styleFilters": [
        "Caption"
      ]
    },
    {
      "ruleId": "font_size_table",
      "type": "numeric",
      "enabled": true,
      "target": "paragraph",
      "property": "fontSize",
      "expectedValue": 11.0,
      "unit": "pt",
      "tolerance": 0.5,
      "severity": "error",
      "description": "Tabeli teksti fondi suurus",
      "message": "Tabeli sees oleva teksti fondi suurus peab olema 11 pt",
      "styleFilters": [
        "Tabletext"
      ]
    },
    {
      "ruleId": "font_size_code",
      "type": "numeric",
      "enabled": true,
      "target": "paragraph",
      "property": "fontSize",
      "expectedValue": 10.0,
      "unit": "pt",
      "tolerance": 0.5,
      "severity": "error",
      "description": "Programmikoodi fondi suurus",
      "message": "Programmikoodi teksti fondi suurus peab olema 10 pt",
      "fontFilters": ["Courier New", "Consolas"]
    },
    {
      "ruleId": "heading_bold",
      "type": "boolean",
      "enabled": true,
      "target": "paragraph",
      "property": "bold",
      "expectedValue": true,
      "severity": "error",
      "description": "I taseme pealkiri on rasvane",
      "message": "I taseme pealkiri peab olema rasvane",
      "styleFilters": [
        "Heading1"
      ]
    },
    {
      "ruleId": "text_alignment",
      "type": "enum",
      "enabled": true,
      "target": "paragraph",
      "property": "alignment",
      "allowedValues": [
        "justified"
      ],
      "severity": "error",
      "description": "Põhiteksti joondus",
      "message": "Põhiteksti joondus peab olema rööpjoondus",
      "styleFilters": [
        "Normal"
      ]
    },
    {
      "ruleId": "subsection_min_paragraphs",
      "type": "count",
      "enabled": true,
      "target": "section",
      "property": "paragraphCount",
      "minValue": 2,
      "severity": "warning",
      "description": "Alampeatüki sisu pikkus",
      "message": "Alampeatükk peaks sisaldama rohkem kui ühte lõiku"
    },
    {
      "ruleId": "sections_order",
      "type": "order",
      "enabled": true,
      "target": "document",
      "orderType": "fixed",
      "expectedOrder": [
        "Lühikokkuvõte",
        "Sisukord",
        "Sissejuhatus",
        "Kokkuvõte",
        "Kasutatud kirjandus"
      ],
      "severity": "error",
      "description": "Lõputöö osade järjekord",
      "message": "Lõputöö osad ei ole õiges järjekorras"
    },
    {
      "ruleId": "glossary_terms_in_text",
      "type": "crossReference",
      "sectionTitle": "Lühendite ja mõistete sõnastik",
      "enabled": true,
      "target": "document",
      "referenceTarget": "bodyText",
      "severity": "error",
      "description": "Lühendite sõnastiku terminid esinevad põhitekstis",
      "message": "Lühendite ja mõistete sõnastiku terminid peavad esinema töö põhitekstis"
    },
    {
      "ruleId": "abstract_language_main",
      "type": "language",
      "enabled": true,
      "target": "section",
      "sectionTitle": "Lühikokkuvõte",
      "expectedLanguage": "et",
      "language": "et",
      "severity": "error",
      "description": "Peamine lühikokkuvõte on eesti keeles",
      "message": "Töö põhikeeles kirjutatud lühikokkuvõte peab olema eesti keeles"
    },
    {
      "ruleId": "main_content_page_count_bachelor",
      "type": "count",
      "enabled": true,
      "target": "document",
      "property": "pageCount",
      "thesisType": "bachelor",
      "minValue": 25,
      "maxValue": 35,
      "severity": "warning",
      "description": "Bakalaureusetöö põhiosa maht",
      "message": "Bakalaureusetöö põhiosa peab üldjuhul olema 25-35 lehekülge"
    },
    {
      "ruleId": "main_content_page_count_master",
      "type": "count",
      "enabled": true,
      "target": "document",
      "property": "pageCount",
      "thesisType": "master",
      "minValue": 30,
      "maxValue": 60,
      "severity": "warning",
      "description": "Magistritöö põhiosa maht",
      "message": "Magistritöö põhiosa peab üldjuhul olema 40-60 lehekülge"
    },
    {
      "ruleId": "appendix_title_format",
      "type": "regex",
      "enabled": true,
      "target": "paragraph",
      "property": "text",
      "pattern": "^Lisa \\d+ \u2013 .+",
      "afterSectionTitle": "Kasutatud kirjandus",
      "severity": "error",
      "description": "Lisa pealkirja formaat",
      "message": "Lisa pealkiri peab algama kujul 'Lisa 1 – Pealkiri'"
    }
  ]
}
