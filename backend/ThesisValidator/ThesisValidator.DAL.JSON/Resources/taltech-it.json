      "ruleName": "main_content_page_count_bachelor",
      "type": "count",
      "enabled": true,
      "target": "document",
      "property": "pageCount",
      "startSectionTitle": "Sissejuhatus",
      "endSectionTitle": "Kokkuvõte",
      "thesisType": "bachelor",
      "minValue": 25,
      "maxValue": 35,
      "unit": "page",
      "severity": "warning",
      "description": "Bakalaureusetöö põhiosa maht on 25-35 lk",
      "message": "Bakalaureusetöö põhiosa peab üldjuhul olema 25-35 ll"
