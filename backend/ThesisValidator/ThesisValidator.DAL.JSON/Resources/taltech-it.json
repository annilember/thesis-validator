      "expectedOrder": [
        "Tiitelleht",
        "Autorideklaratsioon",
        "Lühikokkuvõte",
        "Abstract",
        "Lühendite ja mõistete sõnastik",
        "Sisukord",
        "Jooniste loetelu",
        "Tabelite loetelu",
        "Sissejuhatus",
        "Kokkuvõte",
        "Kasutatud kirjandus",
